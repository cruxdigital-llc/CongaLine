.idea/

# Terraform
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl
tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
terraform/environments/*/backend.tf

# Build artifacts
dist/
bin/
/conga

# MCP config (user-specific)
.mcp.json
.mcp.json.*
!.mcp.json.example

# User-specific policy config
conga-policy.yaml

# Per-agent definitions (may contain client/project-sensitive data).
# Only the underscore-prefixed structural entries are committed.
agents/*/
!agents/_example/
!agents/_defaults/

# Legacy layout (pre-2026-05-XX rename). Operators may still have on-disk
# files under behavior/agents/ until they run scripts/migrate-behavior-to-agents.sh.
# Keep ignored so the loader's backward-compat fallback doesn't surface them.
behavior/agents/*/
!behavior/agents/_example/

# Other local files
demo.*
