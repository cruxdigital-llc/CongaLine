# --- AWS ---
aws_region   = "us-east-2"
aws_profile  = "default"
project_name = "conga-line"

# Path to repo root (for agent overlays, router source, etc.)
repo_root = "/path/to/congaline"

# --- Infrastructure ---
instance_type = "r6g.medium"
alert_email   = ""

# Egress ports — the complete list of allowed outbound traffic.
# Omit to use defaults (HTTPS + DNS). Override to add ports (e.g. VPN).
# Use cidr="vpc" to scope a rule to the VPC CIDR, or cidr="x.x.x.x/32"
# to restrict to a specific endpoint.
# egress_ports = [
#   { protocol = "tcp", port = 443, description = "HTTPS (Slack WSS, LLM APIs, Docker Hub, SSM)" },
#   { protocol = "tcp", port = 53, cidr = "vpc", description = "DNS TCP (VPC resolver)" },
#   { protocol = "udp", port = 53, cidr = "vpc", description = "DNS UDP (VPC resolver)" },
#   { protocol = "udp", port = 51820, description = "WireGuard VPN (self-hosted LLM / private network)" },
# ]

# --- Global Egress Policy ---
# Domains every agent can reach. Per-agent egress_allowed_domains merge
# ADDITIVELY on top of this list (see the agents block below).
egress_mode = "enforce" # "enforce" or "validate"
egress_allowed_domains = [
  # LLM endpoints
  "api.anthropic.com",

  # Messaging platform (Slack example)
  "*.slack.com",
  "*.slack-edge.com",

  # Add any other domains shared by every agent here (OAuth, metrics, etc.)
  # "auth.google.com",
  # "oauth2.googleapis.com",
  # "www.googleapis.com",
  # "accounts.google.com",
]

# --- Global Secrets ---
# Applied to every agent. Each key becomes an env var on the container,
# uppercased with dashes converted to underscores
# (e.g. anthropic-api-key → ANTHROPIC_API_KEY).
global_secrets = {
  "anthropic-api-key" = ""
  # "openai-api-key"   = ""  # if any agent overlay points at an OpenAI-compatible endpoint
}

# --- Agents ---
# Define your fleet. Key is the agent name.
# Ports auto-assigned alphabetically from 18789 if omitted.
#
# egress_allowed_domains merges ADDITIVELY with the global list above (and
# blocked_domains likewise) — only list each agent's *additional* domains
# here. egress_mode replaces the global mode if set. To deny a
# globally-allowed domain for one agent, use egress_blocked_domains on that
# agent. See product-knowledge/standards/egress-controls.md.
#
# Per-agent runtime config (model overrides, prompts) lives in
# agents/<name>/ — see agents/_example/.
agents = {
  myagent = {
    type = "user"
    # Optional: only list the *additional* domains this agent needs beyond
    # the global allowlist above.
    # egress_allowed_domains = ["*.trello.com"]
    # Optional: deny a globally-allowed domain for this agent only.
    # egress_blocked_domains = ["*.slack-edge.com"]
    # Optional: override the global mode for this agent.
    # egress_mode = "validate"
    # Optional: per-agent secrets.
    # secrets = {
    #   "trello-api-key" = "..."
    #   "trello-token"   = "..."
    # }
  }
  myteam = {
    type = "team"
    # No per-agent egress overrides — this agent inherits the global allowlist.
  }
  # Example: a team agent that also reaches a domain none of the others need.
  # specialty-team = {
  #   type                   = "team"
  #   egress_allowed_domains = ["*.linear.com"]
  # }
}

# --- Channels ---
# Each channel has shared secrets and per-agent bindings.
# Bindings map agent name => config with required `id` key.
# Omit entirely to run in gateway-only mode (no messaging platform).
channels = {
  slack = {
    secrets = {
      "slack-bot-token"      = ""
      "slack-signing-secret" = ""
      "slack-app-token"      = ""
    }
    bindings = {
      myagent = { id = "USLACKMEMBERID" }  # Slack member ID
      myteam  = { id = "CSLACKCHANNELID" } # Slack channel ID
    }
  }
  # telegram = {
  #   secrets = {
  #     "telegram-bot-token" = ""
  #   }
  #   bindings = {
  #     myagent = { id = "123456789" }
  #   }
  # }
}
