set -euo pipefail
umask 077
AWS_REGION="{{.AWSRegion}}"
AGENT_NAME="{{.AgentName}}"

get_secret() {
  aws secretsmanager get-secret-value \
    --secret-id "$1" --query SecretString --output text --region "$AWS_REGION"
}

CONGA_IMAGE=$(aws ssm get-parameter --name "/conga/config/image" \
  --query "Parameter.Value" --output text --region "$AWS_REGION")

SLACK_BOT_TOKEN=$(get_secret "conga/shared/slack-bot-token")
SLACK_SIGNING_SECRET=$(get_secret "conga/shared/slack-signing-secret")
GOOGLE_CLIENT_ID=$(get_secret "conga/shared/google-client-id")
GOOGLE_CLIENT_SECRET=$(get_secret "conga/shared/google-client-secret")

cat > /opt/conga/config/$AGENT_NAME.env << EOF
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
EOF

AGENT_SECRETS=$(aws secretsmanager list-secrets \
  --filter Key=name,Values="conga/agents/$AGENT_NAME/" \
  --query 'SecretList[].Name' --output text \
  --region "$AWS_REGION" 2>/dev/null || echo "")

for SP in $AGENT_SECRETS; do
  SV=$(get_secret "$SP")
  SN=$(echo "$SP" | sed "s|conga/agents/$AGENT_NAME/||" | tr '[:lower:]-' '[:upper:]_')
  echo "$SN=$SV" >> /opt/conga/config/$AGENT_NAME.env
done

chmod 0400 /opt/conga/config/$AGENT_NAME.env

ENV_FLAGS=""
while IFS="=" read -r key value; do
  [ -n "$key" ] && ENV_FLAGS="$ENV_FLAGS -e $key"
done < /opt/conga/config/$AGENT_NAME.env

# Extract existing port mapping from current systemd unit
PORT_FLAG=$(grep -oE '\-p 127\.0\.0\.1:[0-9]+:18789' /etc/systemd/system/conga-$AGENT_NAME.service || echo "")

sed -i "s|^ExecStart=.*|ExecStart=/usr/bin/docker run --name conga-$AGENT_NAME --network conga-$AGENT_NAME $PORT_FLAG --cap-drop ALL --security-opt no-new-privileges --memory 2g -e NODE_OPTIONS=\"--max-old-space-size=1536\" --pids-limit 256 -v /opt/conga/data/$AGENT_NAME:/home/node/.openclaw:rw $ENV_FLAGS $CONGA_IMAGE|" /etc/systemd/system/conga-$AGENT_NAME.service

systemctl daemon-reload
systemctl restart conga-$AGENT_NAME

# Reconnect router to agent network (lost on container restart)
docker network connect "conga-$AGENT_NAME" conga-router 2>/dev/null || true

# Re-apply egress iptables rules (if egress proxy config exists)
EGRESS_CONF="/opt/conga/config/egress-$AGENT_NAME.yaml"
if [ -f "$EGRESS_CONF" ]; then
  # Wait for container to be running
  AGENT_IP=""
  for i in $(seq 1 10); do
    AGENT_IP=$(docker inspect -f '{{(index .NetworkSettings.Networks "conga-'$AGENT_NAME'").IPAddress}}' conga-$AGENT_NAME 2>/dev/null || echo "")
    [ -n "$AGENT_IP" ] && break
    sleep 1
  done
  NET_CIDR=$(docker network inspect -f '{{range .IPAM.Config}}{{.Subnet}}{{end}}' conga-$AGENT_NAME 2>/dev/null || echo "")
  if [ -n "$AGENT_IP" ] && [ -n "$NET_CIDR" ]; then
    iptables -C DOCKER-USER -s "$AGENT_IP" -j DROP 2>/dev/null || \
      iptables -I DOCKER-USER -s "$AGENT_IP" -j DROP
    iptables -C DOCKER-USER -s "$AGENT_IP" -d "$NET_CIDR" -j RETURN 2>/dev/null || \
      iptables -I DOCKER-USER -s "$AGENT_IP" -d "$NET_CIDR" -j RETURN
    iptables -C DOCKER-USER -s "$AGENT_IP" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN 2>/dev/null || \
      iptables -I DOCKER-USER -s "$AGENT_IP" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN
    echo "Egress iptables: DROP rules applied for conga-$AGENT_NAME ($AGENT_IP)"
  else
    echo "WARNING: Could not apply egress iptables rules — container IP or subnet not found"
  fi
fi

echo "Secrets refreshed and container restarted for $AGENT_NAME"
