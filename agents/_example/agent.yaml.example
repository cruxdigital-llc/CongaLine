# ------------------------------------------------------------------------------
# agent.yaml — per-agent runtime overlay (OPTIONAL)
#
# Lives at: agents/<agent-name>/agent.yaml
# Format:   YAML, schema v1 (see below)
# Scope:    Provider-agnostic per-agent runtime configuration. Same file
#           produces the same behavior on local, remote, and AWS providers.
#
# WHAT GOES HERE:  model selection, future memory/tools/limits configuration.
# WHAT DOES NOT:   infra (ports, egress IPs → tfvars or CLI), secrets (→ secrets
#                  store, never literal values here), prompts (→ SOUL.md /
#                  AGENTS.md / USER.md alongside this file), policy (→
#                  conga-policy.yaml).
#
# See ../README.md for an overview, and
# product-knowledge/standards/config-taxonomy.md for the full taxonomy
# and decision rule.
#
# Real agent overlays are gitignored. Only this _example file is committed.
# Copy this file as agent.yaml in your own agent's directory and edit.
# ------------------------------------------------------------------------------

# Required. The schema version this document was authored against.
# - 2 is the current version (adds `subagents:` block for in-runtime delegation).
# - 1 is still accepted unchanged for back-compat (Feature #27 documents).
# - A missing `version:` is accepted with a one-time warning (treated as current).
# - Any other value is a hard failure: conga prints "binary too old; upgrade"
#   rather than silently mis-parsing a newer schema.
#
# Schema additions per version:
#   v1: model: block (Feature #27 Local Model Routing)
#   v2: subagents: block (Feature #29 Delegation Routing — see below)
version: 2

# ------------------------------------------------------------------------------
# model — override the agent's LLM provider, model, and endpoint.
#
# Absence = use the runtime's default model (Anthropic for OpenClaw today).
#
# ADDITIVE BEHAVIOR: setting this block changes the agent's *default* model
# (agents.defaults.model.primary in openclaw.json) but keeps the runtime's
# default model in the allowlist. Operators can still /model into the default
# mid-conversation (and back). If you want to fully lock an agent to one
# model, do it at the egress policy layer (remove api.anthropic.com from the
# agent's allowed_domains in terraform.tfvars or conga-policy.yaml), not by
# trimming the allowlist.
# ------------------------------------------------------------------------------
model:
  # Supported providers (case-sensitive lowercase):
  #   ollama  — OpenClaw's native Ollama integration. Use this for any
  #             host running an Ollama daemon (port 11434 by default).
  #             IMPORTANT: do NOT use Ollama's OpenAI-compatible /v1 endpoint
  #             via the `openai` provider below — it breaks tool calling.
  #   openai  — Native OpenAI or any OpenAI-compatible server that follows
  #             the /v1/chat/completions contract (vLLM, llama.cpp --api,
  #             hosted OpenAI itself, etc.).
  provider: ollama

  # Model tag as the provider expects it. For Ollama, this is the NAME column
  # from `ollama list` on the host (e.g. "qwen3:6b", "llama3.3:latest").
  # For OpenAI providers, e.g. "gpt-5.5", "qwen-2.5-72b-instruct".
  name: qwen3:6b

  # Endpoint URL.
  # - For ollama: REQUIRED, and MUST NOT end in /v1 (use the native API root).
  #   Examples:  http://192.168.1.10:11434
  #              http://my-llm-host.lan:11434
  # - For openai: OPTIONAL. Empty = use OpenAI's hosted API at api.openai.com.
  #   Self-hosted servers typically use a /v1 suffix:
  #              http://10.0.0.5:8000/v1
  base_url: http://192.168.1.10:11434

  # Optional capability caps. Set these when the runtime's auto-detected or
  # default values are wrong for your endpoint — typically the case when a
  # proxy (LiteLLM, OpenRouter) advertises one number but the underlying
  # model enforces a lower one.
  #
  # Symptoms that mean you need these:
  #   - Requests fail with HTTP 400 and
  #     "max_completion_tokens cannot be greater than max_model_len" (vLLM)
  #   - Requests fail with "context length exceeded" or similar
  #   - The model registry (`openclaw models list`) shows a `contextWindow`
  #     that doesn't match what the upstream model actually allows
  #
  # context_window: the model's hard cap on prompt + completion tokens
  #                 combined. Sets models.providers.<id>.models[0].contextWindow
  #                 in openclaw.json.
  # max_tokens:     the per-reply output cap. Sets ...models[0].maxTokens.
  #                 Must be ≤ context_window when both are declared.
  # context_window: 131072
  # max_tokens: 8192

# ------------------------------------------------------------------------------
# subagents — declare a cheaper secondary model the orchestrator can delegate
# mechanical work to (lookups, file ops, log parsing, data crunch, format
# conversions). Added in v2; rejected in v1 documents with a friendly
# "bump to version 2" error.
#
# Upstream mechanism:
#   - OpenClaw runtime: agents.defaults.subagents.{model, delegationMode,
#     maxConcurrent} + sessions_spawn tool. See OpenClaw
#     docs/tools/subagents.md and docs/concepts/parallel-specialist-lanes.md.
#   - Hermes runtime: delegation: {model, max_concurrent_children,
#     max_spawn_depth} + delegate_task tool. See Hermes
#     website/docs/user-guide/features/delegation.md.
#
# The orchestrator (this agent's primary model) decides when to spawn a
# subagent — the runtime owns that policy. Conga's job here is just to make
# the subagent model AVAILABLE in the runtime config.
# ------------------------------------------------------------------------------
subagents:
  # Required when the subagents: block is present. Same provider/name/
  # base_url shape as model.* above; same validation (provider enum
  # {ollama, openai}, base_url shape, etc.).
  model:
    provider: openai
    name: qwen-2.5-72b-instruct
    base_url: https://litellm.internal/v1
    # context_window / max_tokens optional — see the model: block above
    # for rationale.
    # context_window: 131072
    # max_tokens: 8192

  # OpenClaw-only: prompt-level nudge to the orchestrator.
  #   "suggest" (default) — gentle nudge to use subagents for slow / long work
  #   "prefer"            — stronger nudge: delegate anything more involved
  #                         than a direct reply
  # Hermes ignores this field (the loader accepts it for forward-compat).
  delegation_mode: suggest

  # Universal: concurrency cap for subagent runs.
  # 0 / absent = use runtime default (OpenClaw ~8, Hermes 3).
  max_concurrent: 4

  # Hermes-only: nesting depth (1..3, default 1).
  # 1 = flat (subagents cannot spawn their own subagents).
  # OpenClaw's nesting policy is implicit; it ignores this field.
  # max_spawn_depth: 1

# ------------------------------------------------------------------------------
# RESERVED KEYS — do NOT use today.
#
# These top-level keys are reserved for future versions. Setting any of them
# in a v1 or v2 document fails the strict-key parser. Listed here so
# contributors know what's coming.
# ------------------------------------------------------------------------------
#
# # Fallback chain for model failover. Requires the Bifrost / Model Routing
# # work (see product-knowledge/ROADMAP.md).
# model:
#   fallbacks:
#     - openai/gpt-5.5
#     - anthropic/claude-opus-4-6
#
# # Per-agent memory backend. Anticipated:
# memory:
#   provider: ollama
#   endpoint: http://...
#
# # Per-agent tool / MCP allowlist.
# tools:
#   allowlist:
#     - github
#     - linear
#
# # Per-agent token / cost limits.
# limits:
#   max_tokens_per_turn: 8192
#   daily_token_cap: 5000000
#
# # Per-agent multi-modal model refs (image / pdf / video).
# images:
#   provider: ollama
#   name: qwen2.5vl:7b
