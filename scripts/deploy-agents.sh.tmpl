#!/bin/bash
set -euo pipefail

AGENT_NAME="$1"
AGENT_TYPE="$2"
AGENT_RUNTIME="${3:-openclaw}"

# Staging directory holds the agent overlays + defaults rsync'd from S3.
STAGING="/opt/conga/agents"
DEFAULT_SUBDIR="_defaults"
AGENT_DIR="$STAGING/$AGENT_NAME"
if [ ! -d "$STAGING" ]; then
  echo "deploy-agents: $STAGING not found; nothing to deploy"
  exit 0
fi

# Runtime-aware workspace path and file ownership
if [ "$AGENT_RUNTIME" = "hermes" ]; then
  WORKSPACE="/opt/conga/data/$AGENT_NAME/workspace"
  OWNER="0:0"
else
  WORKSPACE="/opt/conga/data/$AGENT_NAME/data/workspace"
  OWNER="1000:1000"
fi

# Read Slack identifier for template substitution
SLACK_ID=$(cat "/opt/conga/config/$AGENT_NAME.slack-id" 2>/dev/null || echo "")

DEFAULT_DIR="$STAGING/$DEFAULT_SUBDIR"

# --- SOUL.md: agent-specific > runtime+type default ---
if [ -f "$AGENT_DIR/SOUL.md" ]; then
  cp "$AGENT_DIR/SOUL.md" "$WORKSPACE/SOUL.md"
elif [ -f "$DEFAULT_DIR/$AGENT_RUNTIME/$AGENT_TYPE/SOUL.md" ]; then
  cp "$DEFAULT_DIR/$AGENT_RUNTIME/$AGENT_TYPE/SOUL.md" "$WORKSPACE/SOUL.md"
fi

# --- AGENTS.md: agent-specific > runtime+type default ---
if [ -f "$AGENT_DIR/AGENTS.md" ]; then
  cp "$AGENT_DIR/AGENTS.md" "$WORKSPACE/AGENTS.md"
elif [ -f "$DEFAULT_DIR/$AGENT_RUNTIME/$AGENT_TYPE/AGENTS.md" ]; then
  cp "$DEFAULT_DIR/$AGENT_RUNTIME/$AGENT_TYPE/AGENTS.md" "$WORKSPACE/AGENTS.md"
fi

# --- USER.md: agent-specific > render runtime+type template ---
if [ -f "$AGENT_DIR/USER.md" ]; then
  cp "$AGENT_DIR/USER.md" "$WORKSPACE/USER.md"
elif [ -f "$DEFAULT_DIR/$AGENT_RUNTIME/$AGENT_TYPE/USER.md.tmpl" ]; then
  # Legacy {{AGENT_NAME}} form — can be dropped once all USER.md.tmpl
  # files use {{.AgentName}}.
  sed -e "s|{{.AgentName}}|$AGENT_NAME|g" \
      -e "s|{{AGENT_NAME}}|$AGENT_NAME|g" \
      -e "s|{{.SlackChannel}}|$SLACK_ID|g" \
      -e "s|{{.SlackMemberID}}|$SLACK_ID|g" \
      "$DEFAULT_DIR/$AGENT_RUNTIME/$AGENT_TYPE/USER.md.tmpl" > "$WORKSPACE/USER.md"
fi

# Fix ownership — runtime-aware uid
chown $OWNER "$WORKSPACE/SOUL.md" "$WORKSPACE/AGENTS.md" "$WORKSPACE/USER.md" 2>/dev/null || true

# --- Conga-managed declarative custom-config layers (feature #31) ---
# Deploy the two include files the managed openclaw.json "$include" array
# references, from the S3-synced committed sources:
#   fleet-custom.json          <- _defaults/<runtime>/fleet-custom.json (all agents)
#   agent-managed-custom.json  <- <name>/custom.json                    (per-agent)
# An absent source deploys "{}" — the $include target must exist or the whole
# config is invalid. root:root 0444 keeps them read-only to the agent (uid 1000),
# which still reads them for $include resolution, mirroring agent-custom.json.
# OpenClaw only ($include layering); no-op for hermes.
if [ "$AGENT_RUNTIME" = "openclaw" ]; then
  DATADIR="/opt/conga/data/$AGENT_NAME"
  FLEET_SRC="$DEFAULT_DIR/$AGENT_RUNTIME/fleet-custom.json"
  PERAGENT_SRC="$AGENT_DIR/custom.json"
  if [ -f "$FLEET_SRC" ]; then
    cp "$FLEET_SRC" "$DATADIR/fleet-custom.json"
  else
    printf '{}\n' > "$DATADIR/fleet-custom.json"
  fi
  if [ -f "$PERAGENT_SRC" ]; then
    cp "$PERAGENT_SRC" "$DATADIR/agent-managed-custom.json"
  else
    printf '{}\n' > "$DATADIR/agent-managed-custom.json"
  fi
  chown root:root "$DATADIR/fleet-custom.json" "$DATADIR/agent-managed-custom.json"
  chmod 0444 "$DATADIR/fleet-custom.json" "$DATADIR/agent-managed-custom.json"
fi

echo "Overlay files deployed for $AGENT_NAME ($AGENT_TYPE, $AGENT_RUNTIME) from $STAGING"
